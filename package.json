{
  "name": "project",
  "private": true,
  "packageManager": "npm@11.5.2",
  "scripts": {
    "build": "npm --workspace web run build",
    "dev": "npm --workspace web run dev",
    "lint": "npm --workspace web run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "npm --workspace web run check-types"
  },

  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "5.9.2"
  },

  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
